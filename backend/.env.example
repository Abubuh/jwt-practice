# Copia este archivo a .env y ajusta los valores ( .env no se sube a git )

PORT=3000
SALT_ROUNDS=10

# Secreto para firmar JWT (en local puede ser cualquier string largo; en producción debe ser fuerte y único)
JWT_SECRET=dev-only-cambiar-por-algo-largo-y-aleatorio

# Postgres: local, Supabase o Railway. Ejemplo Supabase (reemplaza usuario, pass y host):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.sbrlsdzpnbljruhedpbb:supabasePassword!@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=no-verify

# Orígenes del front permitidos por CORS (separados por coma). En local suele bastar con Vite:
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# En Railway/Vercel no uses este archivo: configura las mismas variables en el panel del servicio.
